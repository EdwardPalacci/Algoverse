# ============================================================
# DLM Generation Outputs (Pilot)
# ============================================================
#
# One JSON object per line (JSONL format)
#
# Required fields:
# - question_id
# - dataset
# - condition
# - final_answer
# - confidence
# - raw_output
# - parse_success
#
# Optional fields:
# - intermediate_generations
#
# Example:
#
# {
#   "question_id": "gsm8k_00001",
#   "dataset": "gsm8k",
#   "condition": "neutral",
#   "final_answer": "42",
#   "confidence": 0.97,
#   "raw_output": "...",
#   "parse_success": true,
#   "intermediate_generations": [
#     "[MASK] [MASK]",
#     "The answer is [MASK]",
#     "The answer is 42"
#   ]
# }
#
# Actual experiment outputs will be appended below,
# one JSON object per line.
#
# ============================================================
